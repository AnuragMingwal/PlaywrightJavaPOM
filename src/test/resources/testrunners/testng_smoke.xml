<suite name="Smoke Suite">

<listeners>
        <listener class-name="com.qa.opencart.listeners.ExtentReportListener"/>
        <listener class-name="com.qa.opencart.retry.RetryListener"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <packages>
            <package name="com.qa.opencart.tests"/>
        </packages>
    </test>

</suite>