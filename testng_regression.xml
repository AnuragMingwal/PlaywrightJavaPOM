<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OpenCart Regression PW Suite" thread-count="2" parallel="tests
" verbose="4">

    <listeners>
        <listener class-name="com.qa.opencart.listeners.ExtentReportListener"/>
